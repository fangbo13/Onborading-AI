# ===========================
# KnowPilot - Environment Variables
# ===========================

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://knowpilot:knowpilot_password@db:5432/knowpilot

# Redis
REDIS_URL=redis://redis:6379/0

# DashScope API (Qwen LLM + Embeddings)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# RAG Settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=8
RAG_SIMILARITY_THRESHOLD=0.30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Media / File Upload
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=50
